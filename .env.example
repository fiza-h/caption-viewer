# ─── Google Drive API Configuration ─────────────────
# Base64-encoded JSON key for the Google Service Account.
# To encode: base64 -w 0 your-service-account-key.json
# On Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Drive folder IDs (from the URL when you open the folder in Drive)
# e.g. https://drive.google.com/drive/folders/ABC123 → folder ID is ABC123
DRIVE_IMAGES_FOLDER_ID=
DRIVE_JSONS_FOLDER_ID=
